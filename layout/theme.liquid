<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#ffffff">
  <link rel="canonical" href="{{ canonical_url }}">
  <title>{{ page_title }}{% if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif %}{% if current_page != 1 %} &ndash; Page {{ current_page }}{% endif %}{% unless page_title contains shop.name %} &middot; {{ shop.name }}{% endunless %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body class="template-{{ template.name }}{% unless template.name == 'index' %} page-light{% endunless %}">

<div class="announcement">{{ settings.announcement_text | default: "We ship worldwide" }}</div>
<div class="page-overlay" data-overlay></div>
<div class="footer-modal-overlay" data-footer-modal-overlay></div>

<header>
  <div class="header-inner">
    <button class="mobile-menu-trigger" data-mobile-menu-open aria-label="Open menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
        <line x1="3" y1="7" x2="21" y2="7"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="17" x2="21" y2="17"/>
      </svg>
    </button>
    <nav class="primary">
      <button class="nav-trigger" data-dropdown-trigger="shop" aria-expanded="false" aria-controls="dropdown-shop">Shop</button>
    </nav>
    <a href="{{ routes.root_url }}" class="logo" style="text-decoration:none;color:inherit;">CIERI</a>
    <div class="header-utility">
      <a href="#" data-search-open>Search</a>
      <a href="{{ routes.account_url }}">Account</a>
      <a href="#"><span class="cart-label">Cart</span><span class="cart-count">0</span></a>
    </div>
  </div>

  <div class="dropdown dropdown-nested" id="dropdown-shop" data-dropdown="shop">
    <div class="dropdown-nested-inner">

      <!-- Persistent left column: root nav (always visible) -->
      <div class="nested-root">
        <button class="nested-item nested-root-item" data-nested-go="categories">
          <span>Categories</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="9 6 15 12 9 18"/></svg>
        </button>
        <button class="nested-item nested-root-item" data-nested-go="colours">
          <span>Colours</span>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="9 6 15 12 9 18"/></svg>
        </button>
      </div>

      <!-- Expansion column: shows children of whichever root item is active -->
      <div class="nested-expand">
        <div class="nested-sub" data-nested-sub="categories">
          <a href="/collections/all" class="nested-item nested-item-link">All</a>
          <a href="/collections/tops" class="nested-item nested-item-link">Tanks &amp; Tops</a>
          <a href="/collections/bottoms" class="nested-item nested-item-link">Bottoms</a>
          <a href="/collections/dresses" class="nested-item nested-item-link">Dresses</a>
        </div>
        <div class="nested-sub nested-sub-cols" data-nested-sub="colours">
          <div class="nested-col-group">
            <div class="nested-group-label">Signature</div>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#0F0F0F"></span>Black</a>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#FFFFFF;box-shadow:inset 0 0 0 1px rgba(19,24,43,0.18)"></span>White</a>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#5A3D2B"></span>Espresso</a>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#FFF5E5;box-shadow:inset 0 0 0 1px rgba(19,24,43,0.08)"></span>Oat</a>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#DFDFDE"></span>Pebble</a>
          </div>
          <div class="nested-col-group">
            <div class="nested-group-label">Seasonal</div>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#D8E4EE"></span>Alice Blue</a>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#F5EFC8"></span>Lemon Chiffon</a>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#FAE6E8"></span>Blush Pink</a>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#540D07"></span>Dark Cherry</a>
            <a href="/collections/all" class="nested-item nested-swatch-item"><span class="swatch" style="background:#403F3F"></span>Charcoal</a>
          </div>
        </div>
      </div>

      <!-- Feature images on the right -->
      <div class="nested-feature">
        <a href="/collections/best-sellers" class="feature-card">
          <div class="feature-img feature-img-2"></div>
          <div class="feature-label">Best sellers</div>
        </a>
      </div>

    </div>
  </div>
</header>

<div class="mobile-drawer" data-mobile-drawer aria-hidden="true">
  <div class="mobile-drawer-header">
    <span class="mobile-drawer-logo">CIERI</span>
    <button class="mobile-drawer-close" data-mobile-menu-close aria-label="Close menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
        <line x1="5" y1="5" x2="19" y2="19"/>
        <line x1="19" y1="5" x2="5" y2="19"/>
      </svg>
    </button>
  </div>
  <nav class="mobile-drawer-nav">
    <button class="mobile-nav-item mobile-nav-toggle" data-mobile-submenu="shop">
      <span>Shop</span>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="mobile-nav-chevron"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="mobile-submenu" data-mobile-submenu-panel="shop">
      <div class="mobile-submenu-group">
        <div class="mobile-submenu-label">By Category</div>
        <a href="/collections/all">All</a>
        <a href="/collections/tops">Tanks &amp; Tops</a>
        <a href="/collections/bottoms">Bottoms</a>
        <a href="/collections/dresses">Dresses</a>
      </div>
      <div class="mobile-submenu-group">
        <div class="mobile-submenu-label">Signature Colours</div>
        <a href="/collections/all"><span class="swatch" style="background:#0F0F0F"></span>Black</a>
        <a href="/collections/all"><span class="swatch" style="background:#FFFFFF;box-shadow:inset 0 0 0 1px rgba(19,24,43,0.18)"></span>White</a>
        <a href="/collections/all"><span class="swatch" style="background:#5A3D2B"></span>Espresso</a>
        <a href="/collections/all"><span class="swatch" style="background:#FFF5E5;box-shadow:inset 0 0 0 1px rgba(19,24,43,0.08)"></span>Oat</a>
        <a href="/collections/all"><span class="swatch" style="background:#DFDFDE"></span>Pebble</a>
      </div>
      <div class="mobile-submenu-group">
        <div class="mobile-submenu-label">Seasonal Colours</div>
        <a href="/collections/all"><span class="swatch" style="background:#D8E4EE"></span>Alice Blue</a>
        <a href="/collections/all"><span class="swatch" style="background:#F5EFC8"></span>Lemon Chiffon</a>
        <a href="/collections/all"><span class="swatch" style="background:#FAE6E8"></span>Blush Pink</a>
        <a href="/collections/all"><span class="swatch" style="background:#540D07"></span>Dark Cherry</a>
        <a href="/collections/all"><span class="swatch" style="background:#403F3F"></span>Charcoal</a>
      </div>
    </div>
  </nav>
  <div class="mobile-drawer-utility">
    <a href="#" class="mobile-util-item" data-search-open>Search</a>
    <a href="#" class="mobile-util-item">Account</a>
    <a href="#" class="mobile-util-item">Cart (0)</a>
    <button class="mobile-util-item" data-mobile-currency-trigger>USD · United States</button>
  </div>
  <div class="mobile-drawer-footer">
    <a href="https://instagram.com" class="mobile-social">Instagram</a>
    <a href="#" class="mobile-social">TikTok</a>
  </div>
</div>
<div class="mobile-drawer-overlay" data-mobile-drawer-overlay></div>
<div class="mobile-drawer-overlay" data-mobile-drawer-overlay></div>

<main id="MainContent" role="main">
  {{ content_for_layout }}
</main>

<div class="cart-drawer" data-cart-drawer aria-hidden="true">
  <div class="cart-drawer-header">
    <span class="cart-drawer-title">Your Cart <span class="cart-drawer-count" data-cart-drawer-count>(2)</span></span>
    <button class="cart-drawer-close" data-cart-close aria-label="Close cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
        <line x1="5" y1="5" x2="19" y2="19"/>
        <line x1="19" y1="5" x2="5" y2="19"/>
      </svg>
    </button>
  </div>

  <div class="cart-drawer-body" data-cart-body>
    <!-- Cart items -->
    <div class="cart-items">
      <div class="cart-item">
        <div class="cart-item-image pi-1"></div>
        <div class="cart-item-meta">
          <h4 class="cart-item-title">The Wrap Top</h4>
          <div class="cart-item-variant">Oat · Size M</div>
          <div class="cart-item-price">$95.00</div>
          <div class="cart-item-controls">
            <div class="qty-control">
              <button class="qty-btn" aria-label="Decrease">−</button>
              <span class="qty-value">1</span>
              <button class="qty-btn" aria-label="Increase">+</button>
            </div>
            <button class="cart-item-remove" aria-label="Remove">Remove</button>
          </div>
        </div>
      </div>

      <div class="cart-item">
        <div class="cart-item-image pi-3"></div>
        <div class="cart-item-meta">
          <h4 class="cart-item-title">The Bias Skirt</h4>
          <div class="cart-item-variant">Espresso · Size S</div>
          <div class="cart-item-price">$120.00</div>
          <div class="cart-item-controls">
            <div class="qty-control">
              <button class="qty-btn" aria-label="Decrease">−</button>
              <span class="qty-value">1</span>
              <button class="qty-btn" aria-label="Increase">+</button>
            </div>
            <button class="cart-item-remove" aria-label="Remove">Remove</button>
          </div>
        </div>
      </div>
    </div>


    <!-- You may also like (in-drawer) -->
    <div class="cart-ymal" data-cart-ymal>
      <h4 class="cart-ymal-title">You may also like</h4>
      <div class="cart-ymal-track" data-cart-ymal-track>
        <a href="/collections/all" class="cart-ymal-card">
          <div class="cart-ymal-image gi-3"></div>
          <div class="cart-ymal-info">
            <span class="cart-ymal-name">The Bias Skirt</span>
            <span class="cart-ymal-price">$120</span>
          </div>
        </a>
        <a href="/collections/all" class="cart-ymal-card">
          <div class="cart-ymal-image gi-4"></div>
          <div class="cart-ymal-info">
            <span class="cart-ymal-name">The Linen Trouser</span>
            <span class="cart-ymal-price">$155</span>
          </div>
        </a>
        <a href="/collections/all" class="cart-ymal-card">
          <div class="cart-ymal-image gi-6"></div>
          <div class="cart-ymal-info">
            <span class="cart-ymal-name">The Suede Mule</span>
            <span class="cart-ymal-price">$240</span>
          </div>
        </a>
        <a href="/collections/all" class="cart-ymal-card">
          <div class="cart-ymal-image gi-2"></div>
          <div class="cart-ymal-info">
            <span class="cart-ymal-name">The Slip Camisole</span>
            <span class="cart-ymal-price">$85</span>
          </div>
        </a>
        <a href="/collections/all" class="cart-ymal-card">
          <div class="cart-ymal-image gi-5"></div>
          <div class="cart-ymal-info">
            <span class="cart-ymal-name">The Knot Top</span>
            <span class="cart-ymal-price">$110</span>
          </div>
        </a>
        <a href="/collections/all" class="cart-ymal-card">
          <div class="cart-ymal-image gi-1"></div>
          <div class="cart-ymal-info">
            <span class="cart-ymal-name">The Boat Neck</span>
            <span class="cart-ymal-price">$95</span>
          </div>
        </a>
        <a href="/collections/all" class="cart-ymal-card">
          <div class="cart-ymal-image gi-2"></div>
          <div class="cart-ymal-info">
            <span class="cart-ymal-name">The Wide Leg</span>
            <span class="cart-ymal-price">$155</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Empty state (hidden by default) -->
    <div class="cart-empty" data-cart-empty hidden>
      <p class="cart-empty-text">Your cart is empty.</p>
      <button class="btn-line" data-cart-close style="color:var(--ink); border-bottom-color:var(--ink)">Start shopping</button>
    </div>
  </div>

  <div class="cart-drawer-footer">
    <div class="cart-subtotal">
      <span>Subtotal</span>
      <span class="cart-subtotal-value" data-cart-subtotal>$215.00</span>
    </div>
    <div class="cart-shipping-note">Shipping &amp; taxes calculated at checkout</div>
    <button class="cart-checkout-btn">Checkout</button>
  </div>
</div>
<div class="cart-drawer-overlay" data-cart-overlay></div>
<div class="cart-drawer-overlay" data-cart-overlay></div>

<div class="search-drawer" data-search-drawer aria-hidden="true">
  <div class="search-drawer-header">
    <div class="search-input-wrap">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7"/>
        <line x1="21" y1="21" x2="16.5" y2="16.5"/>
      </svg>
      <input type="search" class="search-drawer-input" data-search-input placeholder="Search" autocomplete="off" />
    </div>
    <button class="search-drawer-close" data-search-close aria-label="Close search">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
        <line x1="5" y1="5" x2="19" y2="19"/>
        <line x1="19" y1="5" x2="5" y2="19"/>
      </svg>
    </button>
  </div>

  <div class="search-drawer-body">
    <!-- Empty / default state -->
    <div class="search-default" data-search-default>
      <div class="search-section">
        <div class="search-section-label">Popular searches</div>
        <div class="search-suggestions">
          <button class="search-suggestion" data-search-term="Linen">Linen</button>
          <button class="search-suggestion" data-search-term="Silk">Silk</button>
          <button class="search-suggestion" data-search-term="Dresses">Dresses</button>
          <button class="search-suggestion" data-search-term="Oat">Oat</button>
          <button class="search-suggestion search-suggestion-extra" data-search-term="The Wrap Top">The Wrap Top</button>
        </div>
      </div>

      <div class="search-section">
        <div class="search-section-label">Featured</div>
        <div class="search-products-grid">
          <a href="/collections/all" class="search-product">
            <div class="search-product-image pi-1"></div>
            <div class="search-product-info">
              <span class="search-product-name">The Wrap Top</span>
              <span class="search-product-price">$95</span>
            </div>
          </a>
          <a href="/collections/all" class="search-product">
            <div class="search-product-image pi-3"></div>
            <div class="search-product-info">
              <span class="search-product-name">The Bias Skirt</span>
              <span class="search-product-price">$120</span>
            </div>
          </a>
          <a href="/collections/all" class="search-product">
            <div class="search-product-image pi-2"></div>
            <div class="search-product-info">
              <span class="search-product-name">The Slip Camisole</span>
              <span class="search-product-price">$85</span>
            </div>
          </a>
          <a href="/collections/all" class="search-product">
            <div class="search-product-image pi-4"></div>
            <div class="search-product-info">
              <span class="search-product-name">The Linen Trouser</span>
              <span class="search-product-price">$155</span>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- Results state (hidden by default) -->
    <div class="search-results" data-search-results hidden>
      <div class="search-section-label" data-search-results-label>Results for "—"</div>
      <div class="search-products-grid" data-search-results-grid>
        <!-- Filled dynamically by JS -->
      </div>
      <div class="search-no-results" data-search-no-results hidden>
        <p>No results for "<span data-search-noresults-term></span>".</p>
        <p>Try searching for a fabric, colour, or piece name.</p>
      </div>
    </div>
  </div>
</div>
<div class="search-drawer-overlay" data-search-overlay></div>
<div class="search-drawer-overlay" data-search-overlay></div>

