<div class="cart-page legal-page">
  <h1 class="legal-title">Your bag</h1>
  {% if cart.item_count == 0 %}
    <p>Your bag is empty.</p>
    <a class="add-to-cart-btn" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
  {% else %}
    <form action="{{ routes.cart_url }}" method="post">
      {% for item in cart.items %}
        <div class="cart-line">
          <a href="{{ item.url }}">{{ item.product.title }}</a>
          <span>{{ item.quantity }} &times; {{ item.price | money }}</span>
        </div>
      {% endfor %}
      <div class="cart-subtotal">Subtotal: {{ cart.total_price | money }}</div>
      <button type="submit" name="checkout" class="add-to-cart-btn">Checkout</button>
    </form>
  {% endif %}
</div>

{% schema %}
{
  "name": "Cart",
  "settings": [],
  "presets": [
    {
      "name": "Cart"
    }
  ]
}
{% endschema %}
