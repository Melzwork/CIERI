<div class="care-shell">
  <aside class="sidebar">
    <nav class="sidebar-nav">
      <button class="sidebar-link active" data-tab="faq">FAQ</button>
      <button class="sidebar-link" data-tab="sizing">Sizing &amp; Care</button>
      <button class="sidebar-link" data-tab="shipping">Shipping &amp; Delivery</button>
      <button class="sidebar-link" data-tab="returns">Returns</button>
      <button class="sidebar-link" data-tab="contact">Contact</button>
    </nav>
  </aside>
  <main class="content">

    <div class="panel active" data-panel="faq">
      <h1 class="panel-title">Frequently asked</h1>
      <div class="accordion">
        {% for block in section.blocks %}{% if block.type == "accordion" and block.settings.panel == "faq" %}
        <div class="accordion-item" {{ block.shopify_attributes }}>
          <button class="accordion-trigger">{{ block.settings.heading }}<svg class="accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg></button>
          <div class="accordion-content"><div class="accordion-body">{{ block.settings.body }}</div></div>
        </div>
        {% endif %}{% endfor %}
      </div>
    </div>

    <div class="panel" data-panel="sizing">
      <h1 class="panel-title">Sizing &amp; care</h1>
      <p class="size-section-title"><strong>All measurements are in centimetres, taken from the garment laid flat. If you're between sizes, size down for fitted silhouettes and up for relaxed ones. Please allow a 2-3 cm difference, as each piece is measured by hand.</strong></p>
      <h2>Tops &amp; Tanks</h2><div class="size-table-wrap"><table class="size-table"><thead><tr><th>Size</th><th>Bust</th><th>Waist</th><th>Length</th></tr></thead><tbody><tr><td>S</td><td>66-86</td><td>56-76</td><td>45</td></tr><tr><td>M</td><td>70-90</td><td>60-80</td><td>46</td></tr><tr><td>L</td><td>74-94</td><td>64-84</td><td>47</td></tr><tr><td>XL</td><td>80-100</td><td>70-90</td><td>48</td></tr></tbody></table></div>
      <h2>Bottoms</h2><div class="size-table-wrap"><table class="size-table"><thead><tr><th>Size</th><th>Waist</th><th>Hips</th><th>Thigh</th><th>Pants (Reg)</th><th>Pants (Petite)</th></tr></thead><tbody><tr><td>S</td><td>54-74</td><td>82-102</td><td>46-56</td><td>104</td><td>94</td></tr><tr><td>M</td><td>56-76</td><td>86-106</td><td>48-58</td><td>105</td><td>96</td></tr><tr><td>L</td><td>58-78</td><td>90-110</td><td>50-60</td><td>106</td><td>98</td></tr></tbody></table></div><p>Pants come in Regular and Petite lengths.</p>
      <h2>Skirts</h2><div class="size-table-wrap"><table class="size-table"><thead><tr><th>Size</th><th>Waist</th><th>Hips</th><th>Length</th></tr></thead><tbody><tr><td>S</td><td>58-78</td><td>72-92</td><td>99</td></tr><tr><td>M</td><td>62-82</td><td>74-94</td><td>100</td></tr><tr><td>L</td><td>66-86</td><td>78-98</td><td>101</td></tr><tr><td>XL</td><td>70-90</td><td>84-104</td><td>102</td></tr></tbody></table></div>
      <h2>Dresses</h2><div class="size-table-wrap"><table class="size-table"><thead><tr><th>Size</th><th>Bust</th><th>Waist</th><th>Hip</th><th>Length</th></tr></thead><tbody><tr><td>XS</td><td>84</td><td>66</td><td>90</td><td>108</td></tr><tr><td>S</td><td>88</td><td>70</td><td>94</td><td>109</td></tr><tr><td>M</td><td>92</td><td>74</td><td>98</td><td>110</td></tr><tr><td>L</td><td>96</td><td>78</td><td>102</td><td>111</td></tr><tr><td>XL</td><td>100</td><td>82</td><td>106</td><td>112</td></tr></tbody></table></div>
      <h2>Care</h2><ul><li>Machine wash in cold water with like colours.</li><li>Lay garments separately flat out of direct sunlight to dry.</li><li>Ensure garments are completely dry prior to storing.</li><li>Avoid contact with rough surfaces, as it can cause fabric pulling.</li><li>Take care with perfumes, deodorants, body lotions and makeup, and allow them to dry fully before dressing.</li></ul>
      {% for block in section.blocks %}{% if block.type == "richtext" and block.settings.panel == "sizing" %}
        {% if block.settings.heading != blank %}<h2>{{ block.settings.heading }}</h2>{% endif %}
        {{ block.settings.body }}
        {% endif %}{% endfor %}
    </div>

    <div class="panel" data-panel="shipping">
      <h1 class="panel-title">Shipping &amp; delivery</h1>
      <div class="accordion">
        {% for block in section.blocks %}{% if block.type == "accordion" and block.settings.panel == "shipping" %}
        <div class="accordion-item" {{ block.shopify_attributes }}>
          <button class="accordion-trigger">{{ block.settings.heading }}<svg class="accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg></button>
          <div class="accordion-content"><div class="accordion-body">{{ block.settings.body }}</div></div>
        </div>
        {% endif %}{% endfor %}
      </div>
    </div>

    <div class="panel" data-panel="returns">
      <h1 class="panel-title">Returns</h1>
      <div class="accordion">
        {% for block in section.blocks %}{% if block.type == "accordion" and block.settings.panel == "returns" %}
        <div class="accordion-item" {{ block.shopify_attributes }}>
          <button class="accordion-trigger">{{ block.settings.heading }}<svg class="accordion-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg></button>
          <div class="accordion-content"><div class="accordion-body">{{ block.settings.body }}</div></div>
        </div>
        {% endif %}{% endfor %}
      </div>
    </div>

    <div class="panel" data-panel="contact">
      <h1 class="panel-title">Contact</h1>
      <div class="contact-grid">
        <div>
        {% for block in section.blocks %}{% if block.type == "richtext" and block.settings.panel == "contact" %}
        {% if block.settings.heading != blank %}<h3>{{ block.settings.heading }}</h3>{% endif %}
        {{ block.settings.body }}
        {% endif %}{% endfor %}
        </div>
        {% form 'contact', class: 'contact-form' %}
          {% if form.posted_successfully? %}<p class="contact-success">Thank you. We'll be in touch shortly.</p>{% endif %}
          {{ form.errors | default_errors }}
          <div><label for="cf-name">Name</label><input type="text" id="cf-name" name="contact[name]" value="{{ form.name }}" required></div>
          <div><label for="cf-email">Email</label><input type="email" id="cf-email" name="contact[email]" value="{{ form.email }}" required></div>
          <div><label for="cf-subject">Subject</label><input type="text" id="cf-subject" name="contact[subject]" value="{{ form.subject }}" required></div>
          <div><label for="cf-message">Message</label><textarea id="cf-message" name="contact[body]" required>{{ form.body }}</textarea></div>
          <button type="submit" class="contact-submit">Send message</button>
        {% endform %}
      </div>
    </div>

  </main>
</div>


{% schema %}
{
  "name": "Customer care",
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion item",
      "settings": [
        {
          "type": "select",
          "id": "panel",
          "label": "Show in tab",
          "default": "faq",
          "options": [
            {
              "value": "faq",
              "label": "FAQ"
            },
            {
              "value": "shipping",
              "label": "Shipping & Delivery"
            },
            {
              "value": "returns",
              "label": "Returns"
            }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Question / heading"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Answer / content"
        }
      ]
    },
    {
      "type": "richtext",
      "name": "Text block",
      "settings": [
        {
          "type": "select",
          "id": "panel",
          "label": "Show in tab",
          "default": "contact",
          "options": [
            {
              "value": "sizing",
              "label": "Sizing & Care"
            },
            {
              "value": "contact",
              "label": "Contact"
            }
          ]
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading (optional)"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Text"
        }
      ]
    }
  ],
  "max_blocks": 60,
  "presets": [
    {
      "name": "Customer care"
    }
  ]
}
{% endschema %}
