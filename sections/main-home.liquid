<section class="hero" style="padding:0">
  <div class="hero-image"{% if section.settings.hero_image != blank %} style="background-image:url({{ section.settings.hero_image | image_url: width: 2400 }});background-size:cover;background-position:center;"{% endif %}></div>
</section>

<section class="lookbook">
  <div class="lookbook-grid reveal-stagger">
    {% for i in (1..3) %}
      {% assign img = section.settings['look' | append: i | append: '_image'] %}
      {% assign ttl = section.settings['look' | append: i | append: '_title'] %}
      {% assign lnk = section.settings['look' | append: i | append: '_link'] %}
      <a href="{{ lnk | default: '/collections/all' }}" class="look-card">
        <div class="look-image look-{{ i }}"{% if img != blank %} style="background-image:url({{ img | image_url: width: 1200 }});background-size:cover;background-position:center;"{% endif %}></div>
        <h3 class="look-title">{{ ttl }}</h3>
      </a>
    {% endfor %}
  </div>
</section>

<section class="featured-products">
  <div class="editorial-pair reveal-stagger">
    <a href="{{ section.settings.editorial_link_1 | default: '/collections/all' }}" class="editorial-pair-image pi-1"{% if section.settings.editorial_image_1 != blank %} style="background-image:url({{ section.settings.editorial_image_1 | image_url: width: 1400 }});background-size:cover;background-position:center;"{% endif %}></a>
    <a href="{{ section.settings.editorial_link_2 | default: '/collections/all' }}" class="editorial-pair-image pi-2"{% if section.settings.editorial_image_2 != blank %} style="background-image:url({{ section.settings.editorial_image_2 | image_url: width: 1400 }});background-size:cover;background-position:center;"{% endif %}></a>
  </div>
  <div class="featured-scroller-wrap">
    <button class="featured-scroll-btn featured-scroll-prev" aria-label="Previous"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg></button>
    <button class="featured-scroll-btn featured-scroll-next" aria-label="Next"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></button>
    <div class="featured-scroller reveal-stagger">
      {% if section.settings.featured_collection != blank and section.settings.featured_collection.products.size > 0 %}
        {% for product in section.settings.featured_collection.products limit: 12 %}
          <a href="{{ product.url }}" class="product-card">
            <div class="product-image"{% if product.featured_image %} style="background-image:url({{ product.featured_image | image_url: width: 700 }});background-size:cover;background-position:center;"{% endif %}></div>
            <h3 class="product-title">{{ product.title }}</h3>
            <div class="product-price">{{ product.price | money }}</div>
          </a>
        {% endfor %}
      {% else %}
        {% assign fallback = 'The Bias Skirt|$120|pi-3,The Slip Dress|$180|pi-4,The Cotton Shirt|$110|pi-5,The Knit Vest|$135|pi-6,The Silk Camisole|$95|pi-7,The Crepe Blouse|$125|pi-1,The Tank|$65|pi-2,The Wide Leg|$155|pi-4' | split: ',' %}
        {% for f in fallback %}
          {% assign parts = f | split: '|' %}
          <div class="product-card">
            <div class="product-image {{ parts[2] }}"></div>
            <h3 class="product-title">{{ parts[0] }}</h3>
            <div class="product-price">{{ parts[1] }}</div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<section class="curated-hero reveal">
  <a href="{{ section.settings.curated_link | default: '/collections/all' }}" class="curated-hero-image pi-6"{% if section.settings.curated_image != blank %} style="background-image:url({{ section.settings.curated_image | image_url: width: 2000 }});background-size:cover;background-position:center;"{% endif %}></a>
</section>

<section class="community">
  <div class="community-header reveal">
    <h2 class="section-title">{{ section.settings.community_heading }}</h2>
    {% if section.settings.community_link_label != blank %}<a href="{{ section.settings.community_link_url | default: '#' }}" class="community-link">{{ section.settings.community_link_label }}</a>{% endif %}
  </div>
  <div class="community-grid reveal-stagger">
    {% for i in (1..4) %}
      {% assign cimg = section.settings['community_image_' | append: i] %}
      <div class="community-tile"><div class="ct-bg ct-{{ i }}"{% if cimg != blank %} style="background-image:url({{ cimg | image_url: width: 800 }});background-size:cover;background-position:center;"{% endif %}></div></div>
    {% endfor %}
  </div>
</section>

