<div class="legal-page">
  <h1 class="legal-title">Search</h1>
  <form action="{{ routes.search_url }}" method="get" role="search">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search">
    <button type="submit">Search</button>
  </form>
  {% if search.performed %}
    <div class="product-grid">
      {% for item in search.results %}
        <a href="{{ item.url }}" class="product-card"><div class="product-card-info"><span class="product-card-name">{{ item.title }}</span></div></a>
      {% else %}<p>No results for &ldquo;{{ search.terms }}&rdquo;.</p>{% endfor %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Search",
  "settings": [],
  "presets": [
    {
      "name": "Search"
    }
  ]
}
{% endschema %}
