





<section class="hero" style="padding:0">
  <div class="hero-image"></div>
  <div class="hero-content">
    <h1>The <em>quiet</em><br>edition</h1>
    <div class="hero-sub">Spring · Summer 2026</div>
    <a href="#" class="btn-line">Discover the collection</a>
  </div>
</section>

<section class="lookbook">
  <div class="lookbook-grid reveal-stagger">
    <a href="/collections/tops" class="look-card">
      <div class="look-image look-1"></div>
      <h3 class="look-title">Tops &amp; Tanks</h3>
    </a>
    <a href="/collections/bottoms" class="look-card">
      <div class="look-image look-2"></div>
      <h3 class="look-title">Bottoms</h3>
    </a>
    <a href="/collections/dresses" class="look-card">
      <div class="look-image look-3"></div>
      <h3 class="look-title">Dresses</h3>
    </a>
  </div>
</section>

<section class="featured-products">
  <div class="editorial-pair reveal-stagger">
    <a href="/collections/all" class="editorial-pair-image pi-1"></a>
    <a href="/collections/all" class="editorial-pair-image pi-2"></a>
  </div>
  <div class="featured-scroller-wrap">
    <button class="featured-scroll-btn featured-scroll-prev" aria-label="Previous">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="featured-scroll-btn featured-scroll-next" aria-label="Next">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
    <div class="featured-scroller reveal-stagger">
      <div class="product-card">
        <div class="product-image pi-3"></div>
        <h3 class="product-title">The Bias Skirt</h3>
        <div class="product-price">$120</div>
      </div>
      <div class="product-card">
        <div class="product-image pi-4"></div>
        <h3 class="product-title">The Slip Dress</h3>
        <div class="product-price">$180</div>
      </div>
      <div class="product-card">
        <div class="product-image pi-5"></div>
        <h3 class="product-title">The Cotton Shirt</h3>
        <div class="product-price">$110</div>
      </div>
      <div class="product-card">
        <div class="product-image pi-6"></div>
        <h3 class="product-title">The Knit Vest</h3>
        <div class="product-price">$135</div>
      </div>
      <div class="product-card">
        <div class="product-image pi-7"></div>
        <h3 class="product-title">The Silk Camisole</h3>
        <div class="product-price">$95</div>
      </div>
      <div class="product-card">
        <div class="product-image pi-1"></div>
        <h3 class="product-title">The Crepe Blouse</h3>
        <div class="product-price">$125</div>
      </div>
      <div class="product-card">
        <div class="product-image pi-2"></div>
        <h3 class="product-title">The Tank</h3>
        <div class="product-price">$65</div>
      </div>
      <div class="product-card">
        <div class="product-image pi-4"></div>
        <h3 class="product-title">The Wide Leg</h3>
        <div class="product-price">$155</div>
      </div>
    </div>
  </div>
</section>

<section class="curated-hero reveal">
  <a href="/collections/all" class="curated-hero-image pi-6"></a>
</section>


<section class="community">
  <div class="community-header reveal">
    <h2 class="section-title">In your <em>rotation</em></h2>
    <a href="https://instagram.com" class="community-link">Find us on Instagram</a>
  </div>
  <div class="community-grid reveal-stagger">
    <div class="community-tile"><div class="ct-bg ct-1"></div></div>
    <div class="community-tile"><div class="ct-bg ct-2"></div></div>
    <div class="community-tile"><div class="ct-bg ct-3"></div></div>
    <div class="community-tile"><div class="ct-bg ct-4"></div></div>
  </div>
</section>

